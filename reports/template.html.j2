<!-- ═══════════════════════ JAVASCRIPT ═══════════════════════ -->
<script>{{ underscore_js }}</script>
<script>{{ lodash_js }}</script>
<script>{{ plotly_js }}</script>
<script>{{ phylotree_js }}</script>
<script>
// ── Data ──
const sampleQC = {{ sample_qc_json }};
const locusSummary = {{ locus_summary_json }};
const alignmentSummary = {{ alignment_summary_json }};
const branchMetrics = {{ branch_metrics_json }};
const branchAlternatives = {{ branch_alternatives_json }};
const geneTreeHeterogeneity = {{ gene_tree_heterogeneity_json }};
const topologyCounts = {{ topology_counts_json }};
const speciesTreeNewick = {{ species_tree_newick | tojson }};

const plotlyConfig = {responsive: true, displayModeBar: false};
function plotlyLayout(title, xaxis, yaxis, extra) {
  const base = {
    margin: {l: 200, r: 30, t: 40, b: 60},
    font: {family: '-apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif', size: 12},
    plot_bgcolor: '#fafafa',
    paper_bgcolor: '#ffffff',
    title: {text: title, font: {size: 14}},
    xaxis: {title: xaxis, gridcolor: '#eee'},
    yaxis: {title: yaxis, gridcolor: '#eee'},
  };
  return Object.assign(base, extra || {});
}

// ── BUSCO Completeness ──
(function() {
  const categories = ['single_copy', 'multi_copy', 'fragmented', 'missing'];
  const colors = {'single_copy': '#66c2a5', 'multi_copy': '#fc8d62', 'fragmented': '#8da0cb', 'missing': '#e78ac3'};
  const labels = {'single_copy': 'Single-copy', 'multi_copy': 'Multi-copy', 'fragmented': 'Fragmented', 'missing': 'Missing'};
  const samples = sampleQC.map(s => s.sample_id);
  const traces = categories.map(cat => ({
    y: samples,
    x: sampleQC.map(s => s[cat + '_percent']),
    name: labels[cat],
    type: 'bar',
    orientation: 'h',
    marker: {color: colors[cat]}
  }));
  const maxLabelLen = Math.max(...samples.map(s => s.length)) * 8 + 20;
  Plotly.newPlot('chart-busco', traces, plotlyLayout('', 'Percent (%)', '', {barmode: 'stack', height: Math.max(300, samples.length * 40 + 80), margin: {l: maxLabelLen, r: 30, t: 40, b: 60}}), plotlyConfig);
})();

// ── Missingness ──
(function() {
  const samples = sampleQC.map(s => s.sample_id);
  const maxLabelLen = Math.max(...samples.map(s => s.length)) * 8 + 20;
  const missing = sampleQC.map(s => (s.retained_missing_fraction || 0) * 100);
  const present = missing.map(m => 100 - m);
  Plotly.newPlot('chart-missingness', [
    {y: samples, x: present, name: 'Present', type: 'bar', orientation: 'h', marker: {color: '#3b7a57'}},
    {y: samples, x: missing, name: 'Missing', type: 'bar', orientation: 'h', marker: {color: '#c64e4e'}},
  ], plotlyLayout('', 'Percent of retained loci', '', {barmode: 'stack', height: Math.max(300, samples.length * 40 + 80), margin: {l: maxLabelLen, r: 30, t: 40, b: 60}}), plotlyConfig);
})();

// ── Alignment Length ──
(function() {
  const lengths = alignmentSummary.map(a => Number(a.alignment_length_sites));
  // Build histogram manually for reliability across plotly bundles
  const binSize = 50;
  const minVal = Math.floor(Math.min(...lengths) / binSize) * binSize;
  const maxVal = Math.ceil(Math.max(...lengths) / binSize) * binSize;
  const bins = [];
  const counts = [];
  for (let b = minVal; b < maxVal; b += binSize) {
    bins.push(b + binSize / 2);
    counts.push(lengths.filter(v => v >= b && v < b + binSize).length);
  }
  Plotly.newPlot('chart-alignment', [{
    x: bins, y: counts, type: 'bar',
    marker: {color: '#4c78a8'},
    width: binSize * 0.9,
  }], plotlyLayout('', 'Alignment length ({{ summary.sequence_length_unit }})', 'Number of loci', {height: 350, margin: {l: 60, r: 30, t: 40, b: 60}, bargap: 0.05}), plotlyConfig);
})();

// ── Filtering Outcomes ──
(function() {
  const excluded = locusSummary.filter(l => l.decision !== 'retain' && l.failure_reasons);
  const reasonCounts = {};
  excluded.forEach(l => {
    (l.failure_reasons || '').split(',').forEach(r => {
      r = r.trim();
      if (r) reasonCounts[r] = (reasonCounts[r] || 0) + 1;
    });
  });
  const sorted = Object.entries(reasonCounts).sort((a, b) => b[1] - a[1]);
  if (sorted.length === 0) {
    document.getElementById('chart-filtering').innerHTML = '<p style="color:#6b7280;padding:1rem">No loci were excluded.</p>';
    return;
  }
  const maxLabelLen = Math.max(...sorted.map(s => s[0].length)) * 8 + 20;
  Plotly.newPlot('chart-filtering', [{
    y: sorted.map(s => s[0]),
    x: sorted.map(s => s[1]),
    type: 'bar',
    orientation: 'h',
    marker: {color: '#e17c05'}
  }], plotlyLayout('', 'Excluded loci', '', {height: Math.max(250, sorted.length * 35 + 80), margin: {l: maxLabelLen, r: 30, t: 40, b: 60}}), plotlyConfig);
})();

// ── Branch Support Dot Plot ──
(function() {
  const metricDefs = [
    {key: 'aster_local_posterior', label: 'ASTER support', scale: 100},
    {key: 'aster_q1', label: 'ASTER q1', scale: 100},
    {key: 'gcf', label: 'gCF', scale: 1},
    {key: 'scfl', label: 'sCF', scale: 1},
  ];
  const colors = ['#1b9e77', '#d95f02', '#7570b3', '#e7298a'];
  const labels = branchMetrics.map(b => b.label);
  const traces = metricDefs.map((m, i) => ({
    x: branchMetrics.map(b => (b[m.key] || 0) * m.scale),
    y: labels,
    name: m.label,
    type: 'scatter',
    mode: 'markers',
    marker: {size: 10, color: colors[i]},
  }));
  // Add connecting lines per branch
  const lineTraces = labels.map(label => {
    const vals = metricDefs.map(m => {
      const b = branchMetrics.find(b => b.label === label);
      return (b[m.key] || 0) * m.scale;
    });
    return {
      x: [Math.min(...vals), Math.max(...vals)],
      y: [label, label],
      mode: 'lines',
      line: {color: '#ddd', width: 1},
      showlegend: false,
      hoverinfo: 'skip',
    };
  });
  Plotly.newPlot('chart-branch-support', [...lineTraces, ...traces],
    plotlyLayout('', 'Score (% or concordance factor)', '', {
      height: Math.max(300, labels.length * 50 + 100),
      xaxis: {range: [0, 105], title: 'Score (% or concordance factor)', gridcolor: '#eee'},
    }), plotlyConfig);
})();

// ── Conflict Charts ──
function renderConflictChart(containerId, source, altMap, colors, yLabel) {
  const data = branchAlternatives.filter(d => d.source === source);
  const branches = [...new Set(data.map(d => d.label))];
  const altIds = [...new Set(data.map(d => d.alternative_id))];
  const scale = source === 'aster' ? 100 : 1;
  const traces = altIds.map(alt => ({
    x: branches,
    y: branches.map(b => {
      const row = data.find(d => d.label === b && d.alternative_id === alt);
      return row ? (row.value || 0) * scale : 0;
    }),
    name: altMap[alt] || alt,
    type: 'bar',
    marker: {color: colors[alt]},
  }));
  Plotly.newPlot(containerId, traces, plotlyLayout('', 'Species-tree branch', yLabel, {
    barmode: 'stack', height: 350
  }), plotlyConfig);
}

renderConflictChart('chart-gcf-conflict', 'gcf',
  {main: 'gCF', df1: 'gDF1', df2: 'gDF2', dfp: 'gDFP'},
  {main: '#66c2a5', df1: '#fc8d62', df2: '#8da0cb', dfp: '#e5c494'},
  'Percent (%)');

renderConflictChart('chart-scf-conflict', 'scfl',
  {main: 'sCF', df1: 'sDF1', df2: 'sDF2'},
  {main: '#fbb4ae', df1: '#b3cde3', df2: '#ccebc5'},
  'Percent (%)');

renderConflictChart('chart-aster-conflict', 'aster',
  {t1: 'q1', t2: 'q2', t3: 'q3'},
  {t1: '#8dd3c7', t2: '#ffffb3', t3: '#bebada'},
  'Quartet frequency (%)');

// ── Gene-tree Heterogeneity ──
(function() {
  const complete = geneTreeHeterogeneity.filter(g => g.is_complete_taxon === true);
  const rfValues = complete.map(g => Number(g.rf_distance_to_species_tree)).filter(v => !isNaN(v));
  // Build histogram manually
  const maxRF = Math.max(...rfValues, 1);
  const rfBins = [];
  const rfCounts = [];
  for (let b = 0; b <= maxRF; b++) {
    rfBins.push(b);
    rfCounts.push(rfValues.filter(v => v === b).length);
  }
  Plotly.newPlot('chart-rf', [{
    x: rfBins, y: rfCounts, type: 'bar',
    marker: {color: '#4c78a8'},
  }], plotlyLayout('', 'Robinson-Foulds distance to species tree', 'Number of gene trees', {height: 350, margin: {l: 60, r: 30, t: 40, b: 60}, bargap: 0.05}), plotlyConfig);
})();

(function() {
  const top10 = topologyCounts.slice(0, 10);
  Plotly.newPlot('chart-topologies', [{
    y: top10.map(t => t.topology_id),
    x: top10.map(t => (t.fraction || 0) * 100),
    type: 'bar',
    orientation: 'h',
    marker: {color: top10.map(t => t.matches_species_tree ? '#3b7a57' : '#c64e4e')},
    text: top10.map(t => t.matches_species_tree ? 'Species tree' : 'Alternative'),
    hoverinfo: 'x+text',
  }], plotlyLayout('', 'Complete-taxon gene trees (%)', '', {height: Math.max(300, top10.length * 35 + 80), margin: {l: 60, r: 30, t: 40, b: 60}}), plotlyConfig);
})();

(function() {
  const modelCounts = {};
  geneTreeHeterogeneity.forEach(g => {
    if (g.selected_model) modelCounts[g.selected_model] = (modelCounts[g.selected_model] || 0) + 1;
  });
  const sorted = Object.entries(modelCounts).sort((a, b) => b[1] - a[1]).slice(0, 10);
  const maxModelLen = Math.max(...sorted.map(s => s[0].length)) * 8 + 20;
  Plotly.newPlot('chart-models', [{
    y: sorted.map(s => s[0]),
    x: sorted.map(s => s[1]),
    type: 'bar',
    orientation: 'h',
    marker: {color: '#72b7b2'},
  }], plotlyLayout('', 'Number of loci', '', {height: Math.max(250, sorted.length * 35 + 80), margin: {l: maxModelLen, r: 30, t: 40, b: 60}}), plotlyConfig);
})();

(function() {
  const withSupport = geneTreeHeterogeneity.filter(g => g.support_values_present === true).length;
  const without = geneTreeHeterogeneity.length - withSupport;
  Plotly.newPlot('chart-support-coverage', [{
    x: ['With support', 'Without support'],
    y: [withSupport, without],
    type: 'bar',
    marker: {color: ['#3b7a57', '#c64e4e']},
  }], plotlyLayout('', '', 'Number of gene trees', {height: 300}), plotlyConfig);
})();

// ── Species Tree (Phylotree.js) ──
var currentTreeLayout = 'cladogram';

function setTreeLayout(layout) {
  currentTreeLayout = layout;
  document.getElementById('btn-cladogram').classList.toggle('active', layout === 'cladogram');
  document.getElementById('btn-phylogram').classList.toggle('active', layout === 'phylogram');
  renderTree();
}

function renderTree() {
  const container = document.getElementById('tree-container');
  container.innerHTML = '';

  if (!speciesTreeNewick || !window.phylotree) {
    container.innerHTML = '<p style="padding:1rem;color:#6b7280">Species tree not available.</p>';
    return;
  }

  try {
    const tree = new phylotree.phylotree(speciesTreeNewick);
    const isCladogram = currentTreeLayout === 'cladogram';

    // For cladogram: override branch lengths to equal steps
    if (isCladogram) {
      tree.setBranchLength(function(node) { return undefined; });
    }

    const width = container.clientWidth || 900;
    const tipCount = speciesTreeNewick.split(',').length;
    const height = Math.max(400, tipCount * 50);

    const display = tree.render({
      container: '#tree-container',
      width: width,
      height: height,
      'left-offset': 10,
      'show-scale': isCladogram ? false : 'top',
      'is-radial': false,
      'align-tips': isCladogram,
      'left-right-spacing': 'fit-to-size',
      'top-bottom-spacing': 'fit-to-size',
      'internal-names': true,
      scaling: !isCladogram,
      zoom: true,
      brush: false,
      selectable: false,
      collapsible: false,
      reroot: false,
      'show-menu': false,
      transitions: false,
      'font-size': 14,
    });

    // Style node labels after rendering
    const svg = container.querySelector('svg');
    if (svg) {
      svg.querySelectorAll('.phylotree-node-text').forEach(function(el) {
        const text = (el.textContent || '').trim();
        if (/^B\d+$/.test(text)) {
          // Internal branch labels
          el.style.fontSize = '12px';
          el.style.fontWeight = 'bold';
          el.style.fill = '#2563eb';
        } else if (text.length > 0 && !/^\d/.test(text)) {
          // Tip labels
          el.style.fontSize = '14px';
          el.style.fontFamily = 'monospace';
          el.style.fontStyle = 'italic';
        }
      });
    }
  } catch (e) {
    container.innerHTML = '<p style="padding:1rem;color:#dc2626">Error rendering tree: ' + e.message + '</p>';
    console.error('Tree rendering error:', e);
  }
}

// Initialize tree on load
document.addEventListener('DOMContentLoaded', renderTree);
</script>
</body>
